  { title: 'Char Broil', image: '/wp-content/uploads/2024/01/Sequence-01.00_00_38_07.Still067.png' },
  { title: 'Cricket Manager', image: '/wp-content/uploads/2024/02/Sequence-01.00_22_53_13.Still061.png' },
  { title: 'Kirschgrün', image: '/wp-content/uploads/2024/02/Sequence-01.00_34_31_01.Still064.png' },
  { title: 'Relieve', image: '/wp-content/uploads/2024/02/Sequence-01.00_02_47_15.Still067.jpg' },
  { title: 'Carlo Colucci', image: '/wp-content/uploads/2024/02/Sequence-01.00_11_01_14.Still070.jpg' },
  { title: 'Eightyfiveclo', image: '/wp-content/uploads/2024/04/Image.png' },
];

const schemaProjects = projects.map((p) => ({
  '@type': 'CreativeWork',
  name: p.title,
  creator: { '@id': 'https://elianbeak.de/#person' },
  image: `https://elianbeak.de${p.image}`,
  url: 'https://elianbeak.de/work',
}));
---

<BaseLayout
  title="All Work — Elian Beak"
  description="Audio Engineering und Sound Design Projekte von Elian Beak für BMW, Hyundai, The North Face, Asics, JD Sports, Hisense, Rema und mehr."
  canonical="https://elianbeak.de/work"
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaProjects)} />
  <Nav />

  <main class="pt-32 pb-20 px-6 lg:px-10">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-xs tracking-[0.2em] uppercase text-white/40 mb-12">All Work</h1>
      <WorkGrid projects={projects} priorityCount={3} />
    </div>
  </main>

  <Footer />
</BaseLayout>
