  { title: 'SummerJam', image: '/wp-content/uploads/2024/08/REMA_HOMECOMING_16x9_new.00_02_49_11.Still021.png' },
  { title: 'Veils Around Us', image: '/wp-content/uploads/2024/01/Sequence-01.00_09_07_15.Still028.png' },
  { title: 'Castrol on Mars', image: '/wp-content/uploads/2024/01/Sequence-01.00_13_11_19.Still036.jpg' },
