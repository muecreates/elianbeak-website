---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact — Elian Beak"
  description="Kontakt zu Elian Beak — Audio Engineer und Sound Designer aus Köln. Anfragen für Recording, Mixing, Sound Design und Post Production."
  canonical="https://elianbeak.de/contact"
>
  <Nav />

  <main class="pt-32 pb-20 px-6">
    <div class="max-w-5xl mx-auto">
      <h1 class="text-xs tracking-widest uppercase text-white/40 mb-16">Contact</h1>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        <!-- Form -->
        <div>
          <h2 class="text-2xl md:text-3xl font-light tracking-wide mb-8">
            Let's move together!
          </h2>
          <ContactForm />
        </div>

        <!-- Contact Info -->
        <div class="md:pt-16 flex flex-col gap-8 fade-in">
          <div>
            <span class="text-xs tracking-widest uppercase text-white/40 block mb-2">Phone</span>
            <a
              href="tel:+4922157002248"
              class="text-lg hover:text-white/70 transition-opacity duration-300"
            >
              0221 57002248
            </a>
          </div>

          <div>
            <span class="text-xs tracking-widest uppercase text-white/40 block mb-2">E-Mail</span>
            <a
              href="mailto:contact@elianbeak.de"
              class="text-lg hover:text-white/70 transition-opacity duration-300"
            >
              contact@elianbeak.de
            </a>
          </div>

          <div>
            <span class="text-xs tracking-widest uppercase text-white/40 block mb-2">WhatsApp</span>
            <a
              href="https://wa.me/4922157002248"
              target="_blank"
              rel="noopener noreferrer"
              class="text-lg hover:text-white/70 transition-opacity duration-300"
            >
              Chat on WhatsApp →
            </a>
          </div>

          <div>
            <span class="text-xs tracking-widest uppercase text-white/40 block mb-2">Location</span>
            <span class="text-lg">Cologne, Germany</span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
</script>
