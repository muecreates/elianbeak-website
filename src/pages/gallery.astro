---

<BaseLayout
  title="Gallery — Elian Beak"
  description="35mm Analog Fotografie von Elian Beak. Aufgenommen mit einer Canon auf analogem Film."
  canonical="https://elianbeak.de/gallery"
  ogImage="https://elianbeak.de/wp-content/uploads/2024/02/C060267-R1-17-21-scaled.jpg"
>
  <Nav />

  <main class="pt-28 pb-20 px-4 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="mb-10">
        <h1 class="text-xs tracking-[0.2em] uppercase text-white/40 mb-2">Gallery</h1>
        <p class="text-2xl md:text-3xl font-light tracking-wide">Shot on 35mm</p>
      </div>

      <!-- CSS Masonry via columns -->
      <div class="columns-2 md:columns-3 lg:columns-4 gap-px space-y-px">
        {photos.map((photo, i) => (
          <div class="break-inside-avoid gallery-item" style={`transition-delay: ${Math.min(i * 0.04, 1.2)}s`}>
            <img
              src={photo.src}
              alt={photo.alt}
              width="600"
              height="800"
              loading={i < 8 ? 'eager' : 'lazy'}
              class="w-full h-auto block"
            />
          </div>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .gallery-item {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }
  .gallery-item.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
    }),
    { threshold: 0.04 }
  );
  document.querySelectorAll('.gallery-item').forEach((el) => io.observe(el));
</script>
