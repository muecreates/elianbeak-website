---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import WorkGrid from '../components/WorkGrid.astro';
import Footer from '../components/Footer.astro';

const heroTitle = 'Audio Services';

// Homepage shows first 6 featured projects
const featuredProjects = [
  { title: 'BMW – Auto Shanghai', image: '/wp-content/uploads/2024/01/Sequence-01.00_03_34_03.Still015.png' },
  { title: 'June Freedom – Spiritual', image: '/wp-content/uploads/2025/11/Still-2025-11-26-171302_1.1.4-e1764339782609.jpg' },
  { title: 'Hyundai', image: '/wp-content/uploads/2024/07/Sequence-01.00_00_18_06.Still081.png' },
  { title: 'Asics', image: '/wp-content/uploads/2025/11/Still-2025-11-26-171302_1.3.7-e1764341428933.jpg' },
  { title: 'The North Face', image: '/wp-content/uploads/2024/01/Sequence-01.00_01_46_01.Still010.png' },
  { title: 'JD Sports', image: '/wp-content/uploads/2025/11/Still-2025-11-26-171302_1.2.1.jpg' },
];

const galleryPreview = [
  { src: '/wp-content/uploads/2024/02/C060267-R1-17-21-scaled.jpg', alt: 'Analogfoto auf 35mm Film — Elian Beak Galerie' },
  { src: '/wp-content/uploads/2024/02/C060267-R1-21-25-scaled.jpg', alt: 'Analogfoto auf 35mm Film — urbane Szene' },
  { src: '/wp-content/uploads/2024/02/C060269-R1-17-19-scaled.jpg', alt: 'Analogfoto auf 35mm Film — Architektur' },
  { src: '/wp-content/uploads/2024/02/C060265-R1-17-19-scaled.jpg', alt: 'Analogfoto auf 35mm Film' },
];
---

<BaseLayout
  title="Elian Beak — Audio Services Köln"
  description="Elian Beak ist Audio Engineer und Sound Designer aus Köln. Recording, Mixing, Sound Design und Post Production für BMW, Hyundai, The North Face und mehr."
  canonical="https://elianbeak.de/"
>
  <Nav />

  <!-- HERO: Video background, fullscreen -->
  <section class="relative w-full overflow-hidden" style="height: 100svh; min-height: 600px;">
    <!-- Background video -->
    <video
      autoplay
      loop
      muted
      playsinline
      class="absolute inset-0 w-full h-full object-cover"
      aria-hidden="true"
    >
      <source src="/wp-content/uploads/2024/03/TheNorthFace_MusicFD01a_SFXPZ02a_VO01a_MIX03a.mp4" type="video/mp4" />
    </video>
    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/40"></div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-6">
      <!-- Logo with parallax data attribute -->
      <div id="hero-logo" class="mb-8 hero-logo">
        <img
          src="/wp-content/uploads/2024/03/Logo_Weiss.png"
          alt="Elian Beak"
          width="900"
          height="205"
          fetchpriority="high"
          loading="eager"
          class="w-64 md:w-80 lg:w-96 h-auto"
        />
      </div>

      <!-- "Audio Services" — letter by letter -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-light tracking-[0.12em] uppercase text-white" aria-label="Audio Services">
        {heroTitle.split('').map((char, i) => (
          <span
            class="hero-letter inline-block"
            style={`animation-delay: ${i * 0.055}s`}
            aria-hidden="true"
          >{char === ' ' ? ' ' : char}</span>
        ))}
      </h1>
    </div>
  </section>

  <!-- WORK SECTION -->
  <section class="pt-20 pb-10 px-6 lg:px-10" aria-labelledby="work-heading">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-10 fade-in">
        <h2 id="work-heading" class="text-xs tracking-[0.2em] uppercase text-white/40">Work</h2>
        <a href="/work" class="text-xs tracking-widest uppercase text-white/40 hover:text-white transition-colors duration-300">
          All Work →
        </a>
      </div>
      <WorkGrid projects={featuredProjects} priorityCount={3} />
    </div>
  </section>

  <!-- GALLERY PREVIEW -->
  <section class="py-16 px-6 lg:px-10" aria-labelledby="gallery-heading">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-8 fade-in">
        <h2 id="gallery-heading" class="text-xs tracking-[0.2em] uppercase text-white/40">Shot on 35mm</h2>
        <a href="/gallery" class="text-xs tracking-widest uppercase text-white/40 hover:text-white transition-colors duration-300">
          View Gallery →
        </a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-white/5">
        {galleryPreview.map((photo, i) => (
          <a href="/gallery" class="group block overflow-hidden aspect-square bg-black fade-in" style={`transition-delay: ${i * 0.08}s`}>
            <img
              src={photo.src}
              alt={photo.alt}
              width="400"
              height="400"
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 will-change-transform"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section id="contact" class="py-20 px-6 lg:px-10" aria-labelledby="contact-heading">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        <!-- Left: headline + intro -->
        <div class="fade-in">
          <h2 id="contact-heading" class="text-3xl md:text-4xl font-light tracking-wide mb-4">
            Let's move together!
          </h2>
          <p class="text-white/50 mb-8 leading-relaxed text-sm">
            Contact me for initial consultation or a free personalized offer
          </p>
          <div class="flex flex-col gap-5">
            <div>
              <span class="text-xs tracking-widest uppercase text-white/40 block mb-1">Phone</span>
              <a href="tel:+4922157002248" class="text-base text-white hover:text-white/70 transition-colors duration-300">
                0221 57002248
              </a>
            </div>
            <div>
              <span class="text-xs tracking-widest uppercase text-white/40 block mb-1">E-Mail</span>
              <a href="mailto:contact@elianbeak.de" class="text-base text-white hover:text-white/70 transition-colors duration-300">
                contact@elianbeak.de
              </a>
            </div>
            <div>
              <span class="text-xs tracking-widest uppercase text-white/40 block mb-1">WhatsApp</span>
              <a
                href="https://wa.me/message/YLZUU636TBJJK1"
                target="_blank"
                rel="noopener noreferrer"
                class="text-base text-white hover:text-white/70 transition-colors duration-300"
              >
                Start WhatsApp Chat →
              </a>
            </div>
          </div>
        </div>

        <!-- Right: contact form -->
        <div class="fade-in" style="transition-delay: 0.1s">
          <form
            action="https://formspree.io/f/contact@elianbeak.de"
            method="POST"
            class="flex flex-col gap-4"
            id="contact-form"
          >
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              placeholder="Name"
              class="bg-transparent border border-white/20 px-4 py-3 text-sm text-white placeholder-white/30 focus:outline-none focus:border-white/50 transition-colors duration-300"
            />
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="E-Mail"
              class="bg-transparent border border-white/20 px-4 py-3 text-sm text-white placeholder-white/30 focus:outline-none focus:border-white/50 transition-colors duration-300"
            />
            <input
              type="text"
              name="subject"
              required
              placeholder="Subject"
              class="bg-transparent border border-white/20 px-4 py-3 text-sm text-white placeholder-white/30 focus:outline-none focus:border-white/50 transition-colors duration-300"
            />
            <textarea
              name="message"
              required
              rows="5"
              placeholder="Message"
              class="bg-transparent border border-white/20 px-4 py-3 text-sm text-white placeholder-white/30 focus:outline-none focus:border-white/50 transition-colors duration-300 resize-none"
            ></textarea>
            <!-- Honeypot -->
            <input type="text" name="_gotcha" class="hidden" tabindex="-1" aria-hidden="true" />
            <button
              type="submit"
              class="self-start border border-white/30 px-8 py-3 text-sm tracking-wide hover:bg-white hover:text-black transition-all duration-300"
            >
              Send Message
            </button>
            <p id="form-msg" class="text-sm hidden"></p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* Hero: letter by letter */
  .hero-letter {
    opacity: 0;
    transform: translateY(24px);
    animation: letterUp 0.55s ease forwards;
  }
  @keyframes letterUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Hero logo */
  .hero-logo {
    opacity: 0;
    transform: translateY(16px);
    animation: letterUp 0.7s ease 0.05s forwards;
  }

  /* Scroll fade-in */
  .fade-in {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Intersection observer
  const io = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
    }),
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.fade-in').forEach((el) => io.observe(el));

  // Parallax on hero video (subtle)
  const heroVid = document.querySelector('section video') as HTMLVideoElement | null;
  if (heroVid && window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    window.addEventListener('scroll', () => {
      heroVid.style.transform = `translateY(${window.scrollY * 0.25}px)`;
    }, { passive: true });
  }

  // Contact form
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const msg = document.getElementById('form-msg');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.reset();
        if (msg) { msg.textContent = 'Nachricht gesendet! Ich melde mich bald.'; msg.className = 'text-sm text-white/70'; }
      } else throw new Error();
    } catch {
      if (msg) { msg.textContent = 'Fehler — bitte direkt an contact@elianbeak.de schreiben.'; msg.className = 'text-sm text-red-400'; }
    }
    msg?.classList.remove('hidden');
  });
</script>
