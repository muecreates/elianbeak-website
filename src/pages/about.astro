---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const expertise = [
  'Sound Design',
  'Post Production / Editing',
  'Voice Editing',
  'Music Production',
  'Mixing',
  'Studio Recording',
  'Set Recording',
  'Podcast Recording',
];
---

<BaseLayout
  title="About — Elian Beak"
  description="Elian Beak ist Audio Engineer und Sound Designer aus Köln mit karibischen Wurzeln. Spezialisiert auf Sound Design für Film, Werbung und kreative Projekte."
  canonical="https://elianbeak.de/about"
>
  <Nav />

  <main class="pt-28 pb-20 px-6 lg:px-10">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-xs tracking-[0.2em] uppercase text-white/40 mb-16">About</h1>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24 items-start">
        <!-- Text content -->
        <div class="fade-in order-2 md:order-1">
          <h2 class="text-2xl md:text-3xl font-light tracking-wide mb-8 leading-snug">
            I craft unique sound<br />in a noisy world
          </h2>

          <div class="space-y-5 text-white/70 leading-relaxed text-sm">
            <p>
              Sound is often an overlooked element, yet it plays a crucial role in our perception and experience of the world around us.
            </p>
            <p>
              What truly captivates me is the challenge of creating sound for the unknown. Crafting auditory experiences for things we've never heard before. Imagine the sound of a distant planet, the rumble of a futuristic city, or the ambiance of an undiscovered underwater realm. These are the canvases on which I paint with sound. It's about constantly asking myself, "What could this sound like?"
            </p>
            <p>
              I find peace when immersed in my work. My name is Elian. I'm located in Cologne/Germany and I have roots in Barbados/Caribbean. I think I combine the best from both worlds. The Caribbean fuels my creativity, while Germany fosters my attention to detail and quality.
            </p>
            <p>
              With my analog Canon at my side I also capture life's moments, many of which make it into my web gallery.
            </p>
          </div>

          <!-- Expertise list -->
          <div class="mt-12">
            <span class="text-xs tracking-[0.2em] uppercase text-white/40 block mb-4">Expertise</span>
            <ul class="grid grid-cols-2 gap-y-2 gap-x-8">
              {expertise.map((item) => (
                <li class="text-sm text-white/70 font-light">{item}</li>
              ))}
            </ul>
          </div>

          <a
            href="/#contact"
            class="mt-12 inline-block border border-white/30 px-8 py-3 text-sm tracking-wide hover:bg-white hover:text-black transition-all duration-300"
          >
            Get in touch
          </a>
        </div>

        <!-- Portrait -->
        <div class="order-1 md:order-2 fade-in" style="transition-delay: 0.15s">
          <img
            src="/wp-content/uploads/2024/04/Image.png"
            alt="Elian Beak — Audio Engineer aus Köln"
            width="600"
            height="750"
            loading="lazy"
            class="w-full h-auto object-cover"
          />
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
    }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('.fade-in').forEach((el) => io.observe(el));
</script>
