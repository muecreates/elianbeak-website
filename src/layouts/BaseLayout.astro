---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title = 'Elian Beak — Audio Services Köln',
  description = 'Elian Beak ist Audio Engineer und Sound Designer aus Köln. Recording, Mixing, Sound Design und Post Production für BMW, Hyundai, The North Face und mehr.',
  canonical = Astro.url.href,
  ogImage = 'https://elianbeak.de/wp-content/uploads/2024/03/Logo_Weiss.png',
  noIndex = false,
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <!-- View Transitions -->
    <meta name="view-transition" content="same-origin" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Elian Beak" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="https://elianbeak.de/wp-content/uploads/2024/03/Logo_Weiss_Icon_600x600.png" />

    <!-- Schema.org -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Person",
            "@id": "https://elianbeak.de/#person",
            "name": "Elian Beak",
            "jobTitle": "Audio Engineer & Sound Designer",
            "url": "https://elianbeak.de",
            "email": "contact@elianbeak.de",
            "telephone": "+492215702248",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Cologne",
              "addressCountry": "DE"
            },
            "sameAs": []
          },
          {
            "@type": "LocalBusiness",
            "@id": "https://elianbeak.de/#business",
            "name": "Elian Beak — Audio Services",
            "url": "https://elianbeak.de",
            "email": "contact@elianbeak.de",
            "telephone": "+492215702248",
            "description": "Audio Engineering, Sound Design und Post Production in Köln",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Cologne",
              "addressCountry": "DE"
            },
            "founder": { "@id": "https://elianbeak.de/#person" },
            "serviceType": ["Audio Engineering", "Sound Design", "Mixing", "Post Production"]
          }
        ]
      }
    </script>

    <style>
      /* Custom cursor */
      *, *::before, *::after { cursor: none !important; }

      #cursor {
        position: fixed;
        top: 0;
        left: 0;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: white;
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%, -50%);
        transition: opacity 0.2s ease, transform 0.15s ease, width 0.25s ease, height 0.25s ease, background 0.25s ease;
        will-change: transform;
      }

      #cursor.expanded {
        width: 36px;
        height: 36px;
        background: transparent;
        border: 1px solid rgba(255,255,255,0.6);
        transform: translate(-50%, -50%);
      }

      /* View Transitions fade */
      @view-transition {
        navigation: auto;
      }

      ::view-transition-old(root) {
        animation: vt-fade-out 0.25s ease forwards;
      }
      ::view-transition-new(root) {
        animation: vt-fade-in 0.3s ease forwards;
      }

      @keyframes vt-fade-out {
        from { opacity: 1; }
        to   { opacity: 0; }
      }
      @keyframes vt-fade-in {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
    </style>
  </head>
  <body class="bg-black text-white min-h-screen font-sans antialiased overflow-x-hidden">
    <!-- Custom cursor dot -->
    <div id="cursor" aria-hidden="true"></div>

    <slot />

    <script>
      // Custom cursor
      const cursor = document.getElementById('cursor');
      if (cursor && window.matchMedia('(pointer: fine)').matches) {
        let mx = 0, my = 0;
        document.addEventListener('mousemove', (e) => {
          mx = e.clientX;
          my = e.clientY;
          cursor.style.left = mx + 'px';
          cursor.style.top = my + 'px';
        });

        document.addEventListener('mouseenter', () => cursor.style.opacity = '1');
        document.addEventListener('mouseleave', () => cursor.style.opacity = '0');

        document.addEventListener('mouseover', (e) => {
          const t = e.target as HTMLElement;
          if (t.closest('a, button, [role="button"], input, textarea, select, label')) {
            cursor.classList.add('expanded');
          } else {
            cursor.classList.remove('expanded');
          }
        });
      } else if (cursor) {
        cursor.style.display = 'none';
      }
    </script>
  </body>
</html>
