---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title = 'Elian Beak — Audio Services Köln',
  description = 'Elian Beak ist Audio Engineer und Sound Designer aus Köln. Recording, Mixing, Sound Design und Post Production für BMW, Hyundai, The North Face und mehr.',
  canonical = Astro.url.href,
  ogImage = 'https://elianbeak.de/wp-content/uploads/2024/03/Logo_Weiss.png',
  noIndex = false,
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <!-- View Transitions API -->
    <meta name="view-transition" content="same-origin" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Elian Beak - Audio Services" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/wp-content/uploads/2024/03/cropped-Logo_Black_Icon_600x600-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/wp-content/uploads/2024/03/cropped-Logo_Black_Icon_600x600-192x192.png" />
    <link rel="apple-touch-icon" href="/wp-content/uploads/2024/03/cropped-Logo_Black_Icon_600x600-180x180.png" />

    <!-- Schema.org -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Person",
            "@id": "https://elianbeak.de/#person",
            "name": "Elian Beak",
            "jobTitle": "Audio Engineer & Sound Designer",
            "url": "https://elianbeak.de",
            "email": "contact@elianbeak.de",
            "telephone": "+492215702248",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Cologne",
              "addressCountry": "DE"
            },
            "sameAs": ["https://www.instagram.com/elianbeak"]
          },
          {
            "@type": "LocalBusiness",
            "@id": "https://elianbeak.de/#business",
            "name": "Elian Beak — Audio Services",
            "url": "https://elianbeak.de",
            "email": "contact@elianbeak.de",
            "telephone": "+492215702248",
            "description": "Audio Engineering, Sound Design und Post Production in Köln",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Cologne",
              "addressCountry": "DE"
            },
            "founder": { "@id": "https://elianbeak.de/#person" },
            "serviceType": ["Audio Engineering", "Sound Design", "Mixing", "Post Production", "Voice Editing", "Podcast Recording", "Studio Recording"]
          }
        ]
      }
    </script>

    <style>
      /* Geomanist font */
      @font-face {
        font-family: 'geomanist';
        src: url('/fonts/geomanist.woff2') format('woff2'),
             url('/fonts/geomanist.woff') format('woff');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      /* Custom cursor — only on fine pointer devices */
      @media (pointer: fine) {
        *, *::before, *::after { cursor: none !important; }
      }

      #cursor {
        position: fixed;
        top: 0; left: 0;
        width: 10px; height: 10px;
        border-radius: 50%;
        background: #ffffff;
        pointer-events: none;
        z-index: 9999;
        transform: translate(-50%, -50%);
        transition: width 0.2s ease, height 0.2s ease, background 0.2s ease, opacity 0.2s ease;
        will-change: transform;
        opacity: 0;
      }
      #cursor.expanded {
        width: 32px; height: 32px;
        background: transparent;
        border: 1px solid rgba(255,255,255,0.6);
      }

      /* View Transitions */
      @view-transition { navigation: auto; }
      ::view-transition-old(root) { animation: vt-out 0.22s ease forwards; }
      ::view-transition-new(root) { animation: vt-in 0.28s ease forwards; }
      @keyframes vt-out { to { opacity: 0; } }
      @keyframes vt-in { from { opacity: 0; } }
    </style>
  </head>
  <body class="bg-black text-white min-h-screen font-sans antialiased overflow-x-hidden">
    <div id="cursor" aria-hidden="true"></div>

    <slot />

    <script>
      const cursor = document.getElementById('cursor');
      if (cursor && window.matchMedia('(pointer: fine)').matches) {
        cursor.style.opacity = '1';
        document.addEventListener('mousemove', (e) => {
          cursor.style.left = e.clientX + 'px';
          cursor.style.top = e.clientY + 'px';
        });
        document.addEventListener('mouseleave', () => { cursor.style.opacity = '0'; });
        document.addEventListener('mouseenter', () => { cursor.style.opacity = '1'; });
        document.addEventListener('mouseover', (e) => {
          const t = e.target as HTMLElement;
          cursor.classList.toggle('expanded', !!t.closest('a,button,[role="button"],input,textarea,select'));
        });
      }
    </script>
  </body>
</html>
