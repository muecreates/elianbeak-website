---
interface Props {
  title: string;
  image: string;
  href?: string;
  priority?: boolean;
  index?: number;
}

const { title, image, href = '/work', priority = false, index = 0 } = Astro.props;
---

<a
  href={href}
  class="work-card group relative block overflow-hidden bg-black"
  aria-label={title}
  style={`transition-delay: ${index * 0.07}s`}
>
  <div class="aspect-video overflow-hidden">
    <img
      src={image}
      alt={`${title} — Elian Beak Audio Engineering Projekt`}
      width="800"
      height="450"
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 will-change-transform"
    />
  </div>
  <!-- Overlay: visible on hover -->
  <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
    <span class="text-white text-xl font-light tracking-wide text-center px-4">{title}</span>
  </div>
  <!-- Always visible title below -->
  <div class="px-3 py-2">
    <span class="text-white/80 text-sm font-light tracking-wide">{title}</span>
  </div>
</a>

<style>
  .work-card {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .work-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
