---
const path = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/work', label: 'All Work' },
  { href: '/about', label: 'About' },
  { href: '/gallery', label: 'Gallery' },
];

function isActive(href: string) {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-colors duration-500">
  <div class="flex items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="/" aria-label="Elian Beak – Home" class="shrink-0">
      <img
        src="/wp-content/uploads/2024/03/Logo_Weiss_Icon_600x600.png"
        alt="Elian Beak"
        width="70"
        height="70"
        loading="eager"
        fetchpriority="high"
        class="w-14 h-14 object-contain"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-2" aria-label="Hauptnavigation">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class={`nav-link px-5 py-5 text-sm font-light tracking-wide transition-colors duration-300 ${
            isActive(href) ? 'text-white' : 'text-white/60 hover:text-white/90'
          }`}
        >
          {label}
        </a>
      ))}
      <!-- Contact CTA -->
      <a href="/#contact" class="nav-cta flex items-center gap-2 ml-4 px-4 py-2 text-sm font-light tracking-wide border border-white/30 hover:border-white/60 transition-all duration-300">
        <img
          src="/wp-content/uploads/2023/12/79102-200-1.png"
          alt=""
          aria-hidden="true"
          width="25"
          height="25"
          class="w-6 h-6 object-contain"
        />
        <span class="flex flex-col leading-tight text-left">
          <span class="text-xs font-semibold">Contact</span>
          <span class="text-[10px] text-white/70">Let's move together!</span>
        </span>
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      class="md:hidden flex flex-col gap-[5px] p-2"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <span class="bar block w-6 h-px bg-white transition-all duration-300 origin-center"></span>
      <span class="bar block w-6 h-px bg-white transition-all duration-300"></span>
      <span class="bar block w-6 h-px bg-white transition-all duration-300 origin-center"></span>
    </button>
  </div>
</header>

<!-- Mobile fullscreen menu -->
<div
  id="mobile-nav"
  class="fixed inset-0 z-40 bg-black flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
  {links.map(({ href, label }) => (
    <a href={href} class="text-[40px] font-light tracking-widest text-white/90 hover:text-white transition-colors duration-300">
      {label}
    </a>
  ))}
  <a href="/#contact" class="mt-4 text-xl font-light text-white/80 border border-white/30 px-8 py-4 hover:bg-white hover:text-black transition-all duration-300">
    Let's move together!
  </a>
</div>

<style>
  /* Underline slide animation on desktop nav links */
  .nav-link {
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 14px;
    left: 20px;
    right: 20px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  .nav-link:hover::after,
  .nav-link[data-active]::after {
    transform: scaleX(1);
  }

  /* Scrolled state */
  #site-header.scrolled {
    background-color: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
</style>

<script>
  // Hamburger toggle
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  const bars = toggle?.querySelectorAll('.bar') as NodeListOf<HTMLElement> | undefined;
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    toggle.setAttribute('aria-expanded', String(open));
    menu?.setAttribute('aria-hidden', String(!open));
    if (open) {
      menu?.classList.remove('opacity-0', 'pointer-events-none');
      menu?.classList.add('opacity-100');
      if (bars) {
        bars[0].style.transform = 'rotate(45deg) translateY(6px)';
        bars[1].style.opacity = '0';
        bars[2].style.transform = 'rotate(-45deg) translateY(-6px)';
      }
    } else {
      menu?.classList.add('opacity-0', 'pointer-events-none');
      menu?.classList.remove('opacity-100');
      if (bars) {
        bars[0].style.transform = '';
        bars[1].style.opacity = '';
        bars[2].style.transform = '';
      }
    }
  });

  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      open = false;
      menu.classList.add('opacity-0', 'pointer-events-none');
      menu.classList.remove('opacity-100');
      if (bars) {
        bars[0].style.transform = '';
        bars[1].style.opacity = '';
        bars[2].style.transform = '';
      }
    });
  });

  // Scroll-based header background
  const header = document.getElementById('site-header');
  const onScroll = () => {
    header?.classList.toggle('scrolled', window.scrollY > 60);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
